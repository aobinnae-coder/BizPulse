{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "Business profile and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "brandColor": { "type": "string" },
        "address": { "type": "string" },
        "industry": { "type": "string" },
        "ownerUid": { "type": "string" },
        "currency": { "type": "string", "default": "USD" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerUid"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory item or service",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "threshold": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "draft"] },
        "variants": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string" }
      },
      "required": ["businessId", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "couponCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "ready", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["paid", "pending", "failed", "refunded"] },
        "trackingNumber": { "type": "string" },
        "carrier": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["businessId", "total", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount codes",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "active": { "type": "boolean" },
        "expiryDate": { "type": "string" },
        "usageLimit": { "type": "number" },
        "usageCount": { "type": "number" }
      },
      "required": ["businessId", "code", "type", "value"]
    },
    "Survey": {
      "title": "Survey",
      "description": "A customer feedback survey",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["star", "nps", "choice", "text", "long_text", "toggle", "ranking"] },
              "label": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "required": { "type": "boolean" }
            }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "requireContact": { "type": "boolean" },
            "active": { "type": "boolean" },
            "startDate": { "type": "string" },
            "endDate": { "type": "string" },
            "responseLimit": { "type": "number" }
          }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["businessId", "title", "questions"]
    },
    "Response": {
      "title": "Response",
      "description": "A customer's response to a survey",
      "type": "object",
      "properties": {
        "surveyId": { "type": "string" },
        "businessId": { "type": "string" },
        "orderId": { "type": "string" },
        "answers": { "type": "object" },
        "respondent": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "sentiment": { "type": "string", "enum": ["positive", "neutral", "negative"] },
        "score": { "type": "number" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["new", "reviewed", "flagged", "archived"] },
        "createdAt": { "type": "string" }
      },
      "required": ["surveyId", "businessId", "answers"]
    },
    "ActionItem": {
      "title": "Action Item",
      "description": "A task created to close the feedback loop",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "responseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "dueDate": { "type": "string" },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["businessId", "title", "status"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer directory entry",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["businessId", "email"]
    },
    "PlatformSettings": {
      "title": "Platform Settings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "isPlatformSuspended": { "type": "boolean" },
        "stripeSecretKey": { "type": "string" },
        "sendGridApiKey": { "type": "string" },
        "bgCheckApiKey": { "type": "string" },
        "defaultCurrency": { "type": "string" }
      }
    },
    "TaskTemplate": {
      "title": "Task Template",
      "description": "Reusable task templates",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string" },
        "subtasks": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["businessId", "name"]
    },
    "TaskComment": {
      "title": "Task Comment",
      "description": "Comment on an action item",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Subtask": {
      "title": "Subtask",
      "description": "A smaller task within an action item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "done": { "type": "boolean" },
        "dueDate": { "type": "string" },
        "parentId": { "type": "string" },
        "attachments": { "type": "array" },
        "createdAt": { "type": "string" }
      }
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Log of changes to a task",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "details": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "TimeLog": {
      "title": "Time Log",
      "description": "Time spent on a task",
      "type": "object",
      "properties": {
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "number" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/businesses/{businessId}": { "schema": "Business", "description": "Business settings" },
    "/products/{productId}": { "schema": "Product", "description": "Inventory items" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/coupons/{couponId}": { "schema": "Coupon", "description": "Discount coupons" },
    "/surveys/{surveyId}": { "schema": "Survey", "description": "Survey definitions" },
    "/responses/{responseId}": { "schema": "Response", "description": "Survey responses" },
    "/actionItems/{itemId}": { "schema": "ActionItem", "description": "Action items for feedback loop" },
    "/actionItems/{itemId}/comments/{commentId}": { "schema": "TaskComment", "description": "Comments on a task" },
    "/actionItems/{itemId}/subtasks/{subtaskId}": { "schema": "Subtask", "description": "Subtasks for a task" },
    "/actionItems/{itemId}/activity/{logId}": { "schema": "ActivityLog", "description": "Activity history for a task" },
    "/actionItems/{itemId}/timeLogs/{logId}": { "schema": "TimeLog", "description": "Time logs for a task" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer directory" },
    "/platformSettings/{id}": { "schema": "PlatformSettings", "description": "Global settings" },
    "/taskTemplates/{templateId}": { "schema": "TaskTemplate", "description": "Task templates" },
    "/staff/{staffId}": { "schema": "object", "description": "Staff list" }
  }
}
