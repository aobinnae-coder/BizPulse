rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == 'a.obinnae@skyrouteusa.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBusinessOwner(businessId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/businesses/$(businessId)) &&
        get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid == request.auth.uid;
    }

    // ===============================================================
    // Admin Access (Global)
    // ===============================================================
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /platformSettings/{id} {
      allow read: if true; // Public for platform status
    }

    match /businesses/{businessId} {
      allow read: if true; // Public for storefront
      allow create: if isEmailVerified() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isEmailVerified() && resource.data.ownerUid == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isEmailVerified() && isBusinessOwner(request.resource.data.businessId);
      allow update, delete: if isEmailVerified() && isBusinessOwner(resource.data.businessId);
    }

    match /orders/{orderId} {
      allow read: if (isSignedIn() && isBusinessOwner(resource.data.businessId)) || 
                   (resource.data.customerId != null && request.auth.uid == resource.data.customerId);
      allow create: if true; // Public checkout
      allow update: if isEmailVerified() && isBusinessOwner(resource.data.businessId);
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isEmailVerified() && isBusinessOwner(request.resource.data.businessId);
      allow update, delete: if isEmailVerified() && isBusinessOwner(resource.data.businessId);
    }

    match /surveys/{surveyId} {
      allow read: if true;
      allow create: if isEmailVerified() && isBusinessOwner(request.resource.data.businessId);
      allow update, delete: if isEmailVerified() && isBusinessOwner(resource.data.businessId);
    }

    match /responses/{responseId} {
      allow read: if isEmailVerified() && isBusinessOwner(resource.data.businessId);
      allow create: if true; // Public submission
      allow update: if isEmailVerified() && isBusinessOwner(resource.data.businessId);
    }

    match /actionItems/{itemId} {
      allow read: if isEmailVerified() && (
        isBusinessOwner(resource.data.businessId) || 
        resource.data.assignedTo == request.auth.uid ||
        exists(/databases/$(database)/documents/staff/$(request.auth.uid))
      );
      allow create: if isEmailVerified() && isBusinessOwner(request.resource.data.businessId);
      allow update, delete: if isEmailVerified() && (
        isBusinessOwner(resource.data.businessId) ||
        resource.data.assignedTo == request.auth.uid
      );

      match /comments/{commentId} {
        allow read, create: if isEmailVerified();
      }
      match /subtasks/{subtaskId} {
        allow read, write: if isEmailVerified();
      }
      match /activity/{logId} {
        allow read, create: if isEmailVerified();
      }
      match /timeLogs/{logId} {
        allow read, write: if isEmailVerified();
      }
    }

    match /customers/{customerId} {
      allow read, write: if isEmailVerified() && isBusinessOwner(resource.data.businessId || request.resource.data.businessId);
    }

    match /taskTemplates/{templateId} {
      allow read, write: if isEmailVerified() && isBusinessOwner(resource.data.businessId || request.resource.data.businessId);
    }

    match /staff/{staffId} {
      allow read: if isEmailVerified() && (
        isBusinessOwner(resource.data.businessId) || 
        request.auth.token.email == resource.data.email ||
        // Staff can see colleagues
        exists(/databases/$(database)/documents/businesses/$(resource.data.businessId))
      );
      allow write: if isEmailVerified() && isBusinessOwner(request.resource.data.businessId || resource.data.businessId);
    }

    match /notifications/{notificationId} {
      allow read, update: if isEmailVerified() && isBusinessOwner(resource.data.businessId);
      allow create: if true;
    }
  }
}
